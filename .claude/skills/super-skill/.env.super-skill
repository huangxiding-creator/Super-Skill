# Super-Skill Evolution Configuration
# Capability-Evolver configuration for Super-Skill V3.1

# Evolution Strategy
EVOLVE_STRATEGY=balanced

# Evolution Target
EVOLVE_TARGET=C:\Users\91216\.claude\skills\super-skill

# Evolution Constraints
EVOLVE_ALLOW_SELF_MODIFY=false
EVOLVE_CRITICAL_PATHS=SKILL.md,scripts/auto_update.py,scripts/package_skill.py

# Evolution Triggers
EVOLVE_ON_PROJECT_COMPLETE=true
EVOLVE_ON_CRITICAL_ERROR=false
EVOLVE_ON_USER_FEEDBACK=true

# Evolution Frequency
EVOLVE_MIN_INTERVAL_HOURS=1
EVOLVE_MAX_PROJECTS_BEFORE_EVOLUTION=5

# Evolution Analysis Focus
EVOLVE_ANALYSIS_DEPTH=deep
EVOLVE_SESSION_HISTORY_LIMIT=10

# Evolution Safety
EVOLVE_AUTO_APPLY=true
EVOLVE_BACKUP_BEFORE_EVOLVE=true
EVOLVE_VERSION_TRACKING=true

# Evolution Notifications
EVOLVE_NOTIFY_ON_EVOLUTION=true
EVOLVE_SUMMARY_FILE=EVOLUTION_SUMMARY.md

# Evolution Logging
EVOLVE_LOG_LEVEL=info
EVOLVE_LOG_FILE=evolution.log

# GEP Protocol Configuration
GEP_MUTATION_RATE=0.3
GEP_PERSONALITY_STATE=adaptive
GEP_EVOLUTION_EVENT_TYPE=optimization
GEP_GENE_EXPRESSION=full
GEP_CAPSULE_INTEGRITY=strict
